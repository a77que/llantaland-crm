generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  VENDEDOR
}

enum TipoDoc {
  DNI
  RUC
  CE
  PASAPORTE
}

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
  CONVERTIDA
}

enum TipoSede {
  TIENDA
  ALMACEN
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  TRASLADO
}

enum EstadoVenta {
  PENDIENTE
  COMPLETADA
  ANULADA
}

enum TipoDescuento {
  PORCENTAJE
  MONTO
}

enum TipoComprobante {
  BOLETA
  FACTURA
  NOTA_CREDITO
}

enum EstadoComprobante {
  PENDIENTE
  EMITIDO
  ACEPTADO
  RECHAZADO
}

enum PseProvider {
  NUBEFACT
  APISUNAT
  GREENTER
}

enum OrigenWebhook {
  N8N
  WHATSAPP
  API_EXTERNA
}

// Ranking de lead (calidad de la oportunidad)
enum RankingLead {
  caliente
  tibio
  frio
}

// Caso del flujo (A=stock directo, B=traslado, C=almacen, D=despacho, E=provincia)
enum CasoFlujo {
  A
  B
  C
  D
  E
}

// Negocio al que pertenece el registro (CRM compartido, varias verticales)
enum TipoNegocio {
  LLANTAS
  PATRON
}

enum TipoPersonaje {
  PATRON
  PATRONA
  OSO_MARIACHI
}

enum TipoAgregado {
  RAMO_FLORES
  CHOCOLATES
  PELUCHE
  OTRO
}

// ─── USUARIOS Y SESIONES ─────────────────────────────────────────────────────

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  rol       Rol      @default(VENDEDOR)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  sesiones         Sesion[]
  ventas           Venta[]
  cotizaciones     Cotizacion[]
  movimientosStock MovimientoStock[]
  webhookLogs      WebhookLog[]

  @@map("usuarios")
}

model Sesion {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiresAt DateTime
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesiones")
}

// ─── SEDES / LOCALES ─────────────────────────────────────────────────────────
// Replica hoja LOCALES del Google Sheet

model Sede {
  id          String   @id @default(cuid())
  codigoLocal String   @unique  // L0, L1, L2, L3, L4, L5 — clave usada por n8n
  nombre      String
  tipo        TipoSede @default(TIENDA)
  distrito    String?
  direccion   String?
  telefono    String?
  email       String?
  horario     String?
  encargado   String?
  latitud     String?
  longitud    String?
  googleMaps  String?  // link de Google Maps de la tienda (se envía al cerrar la cita)
  activo      Boolean  @default(true)

  stocks          Stock[]
  movimientos     MovimientoStock[]
  alertasStock    AlertaStock[]
  itemsVenta      ItemVenta[]

  @@map("sedes")
}

// ─── CATÁLOGO / INVENTARIO ───────────────────────────────────────────────────
// Replica hoja PRECIOS del Google Sheet

model Producto {
  id              String       @id @default(cuid())
  sku             String       @unique
  medida          String                         // e.g. "195/65R15" (forma original/visible)
  medidaNorm      String?                        // clave canónica de búsqueda (normalizarMedida)
  marca           String
  nombreComercial String?                        // Nombre_Comercial en sheet
  modelo          String?                        // Modelo específico de la llanta
  runFlat         Boolean?                       // ¿Es run-flat? (Sí / No)
  tipoLlanta      String?                        // Tipo de llanta: Carga, Ciudad, Pistera, MT, AT, etc.
  tipoVehiculo    String?                        // Para qué carro va: Pick up, Sedán, Transporte urbano, etc.
  grupo           String?                        // Grupo (Turismo, SUV, etc.)
  precioRegular   Decimal      @db.Decimal(10, 2)
  precioOferta    Decimal?     @db.Decimal(10, 2) // null = sin oferta
  precioProveedor        Decimal? @db.Decimal(10, 2) // costo base del proveedor (para calcular precio de venta)
  precioReferencialVenta Decimal? @db.Decimal(10, 2) // precio de mercado actual (referencia)
  imagenUrl       String?                        // URL imagen en sheet PRECIOS
  // Ficha técnica
  indice_carga           String?
  velocidad_max          String?
  garantia               String?
  descuentoMaximo        Decimal?  @db.Decimal(5, 2)
  fichaTecnica           String?   @db.Text
  // Ficha técnica ampliada
  cargaMaxNeumatico      Int?                       // kg por neumático (del índice de carga)
  velocidadMaxKmh        Int?                       // km/h máxima (del índice de velocidad)
  eficienciaCombustible  String?                    // Etiqueta EU: A/B/C/D/E
  eficienciaFrenado      String?                    // Etiqueta EU: A/B/C/D/E
  nivelRuido             Int?                       // Nivel de ruido en dB
  paisFabricacion        String?                    // Ej: "Japón"
  origenMarca            String?                    // País de origen de la marca
  camposExtra            Json?                      // campos personalizados dinámicos
  activo          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  stocks      Stock[]
  movimientos MovimientoStock[]
  alertasStock AlertaStock[]
  itemsVenta  ItemVenta[]

  @@index([medida])
  @@index([medidaNorm])
  @@index([marca])
  @@index([activo])
  @@map("productos")
}

// Conceptos de costo GLOBALES que se suman al precio proveedor para llegar al
// precio de venta (IGV, instalación, traslado, etc.). Configurables por el admin.
model CostoVenta {
  id          String   @id @default(cuid())
  nombre      String
  tipo        String   @default("fijo")            // 'fijo' = monto S/ ; 'porcentaje' = % sobre el precio proveedor
  valor       Decimal  @default(0) @db.Decimal(10, 2)
  montoMinimo Decimal? @db.Decimal(10, 2)           // piso en S/: si el % calculado da menos que esto, se usa este monto (hoy solo aplica al concepto "Ganancia")
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("costos_venta")
}

model Stock {
  id          String   @id @default(cuid())
  productoId  String
  sedeId      String
  cantidad    Int      @default(0)
  stockMinimo Int      @default(3)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sede     Sede     @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([productoId, sedeId])
  @@map("stock")
}

model MovimientoStock {
  id         String         @id @default(cuid())
  productoId String
  sedeId     String
  tipo       TipoMovimiento
  cantidad   Int
  referencia String?
  usuarioId  String?                              // nullable para SetNull al borrar usuario
  createdAt  DateTime       @default(now())

  // Restrict: no borrar producto/sede con movimientos en auditoría
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  sede     Sede     @relation(fields: [sedeId], references: [id],     onDelete: Restrict)
  // SetNull: conservar historial de auditoría si se elimina usuario
  usuario  Usuario? @relation(fields: [usuarioId], references: [id],  onDelete: SetNull)

  @@map("movimientos_stock")
}

// ─── LEADS / CRM WHATSAPP ────────────────────────────────────────────────────
// Replica hoja CRM del Google Sheet — un registro por número de teléfono

model LeadCRM {
  id                     String      @id @default(cuid())
  telefono               String      @unique       // clave principal = Telefono del sheet
  timestamp              DateTime    @default(now())
  tipoNegocio            TipoNegocio @default(LLANTAS)

  // Datos del cliente (se completan durante el flujo)
  nombreCliente          String?
  dniCe                  String?
  tipoDoc                TipoDoc?
  marcaAuto              String?
  modeloAuto             String?
  anioAuto               Int?

  // Estado del flujo
  pasoActual             String      @default("nuevo")
  intentosMedida         Int         @default(0)
  emailSeguimientoEnviado Boolean    @default(false)
  // Recuperación de carrito (recordatorios automáticos 15min / 3h / 21h)
  recordatorio15         Boolean     @default(false)
  recordatorio3h         Boolean     @default(false)
  recordatorio21h        Boolean     @default(false)
  hashMensaje            String?     // deduplicación

  // Producto / llanta de interés
  medidaDetectada        String?
  marcaLlanta            String?
  modeloLlanta           String?
  precioLlanta           Decimal?    @db.Decimal(10, 2)
  cantidadLlantas        Int         @default(1)
  tipoServicio           String?     // caso A/B/C/D/E
  ranking                RankingLead?

  // Logística
  distritoCliente        String?
  provinciaDestino       String?
  localAsignado          Json?       // JSON objeto tienda asignada
  localInstalacion       Json?       // JSON tienda instalación confirmada
  localOrigenTraslado    Json?
  // Tienda que el cliente elige ANTES de ver las marcas (para priorizar el
  // catálogo por rentabilidad + stock ahí mismo). Separado de Estado_Flujo a
  // propósito: ese campo se sobrescribe por completo en el paso de elección
  // de marca con el mapa número->marca, así que no es seguro mezclar datos
  // ahí — ver n8nController.js.
  tiendaTempranoId       String?
  esProvinciaTemprano    Boolean?    @default(false)
  estadoFlujo            Json?       // JSON blob con estado completo del flujo
  stockMap               Json?       // mapa stock por local
  ofertaPrecios          Json?       // opciones presentadas al cliente

  // Negocio "El Patrón" (shows de personajes)
  personajeId            String?
  distritoEvento         String?
  costoMovilidadAprox    Decimal?    @db.Decimal(10, 2)
  agregadosSeleccionados Json?       // [{ agregadoId, nombre, precio }]
  esProvincia            Boolean?

  // Cierre
  estadoLogistica        String?
  fechaCita              String?
  calendarEventId        String?

  // Cita / instalación (gestión desde CRM)
  estadoCita             String?     @default("RECIBIDO") // RECIBIDO | ATENDIDO | ENTREGADO
  fechaInstalacion       DateTime?   // día que el cliente irá a la tienda elegida
  horaInstalacion        String?     // hora de instalación (ej: "15:30")
  origenCita             String?     @default("whatsapp") // whatsapp | crm (cotización walk-in)

  // Marcado manual desde el CRM: el vendedor confirmó que el cliente no desea
  // nada. No null = descartado (se excluye de "pendientes por atender"); al
  // marcarlo también se resetea pasoActual a "nuevo" para que, si el cliente
  // vuelve a escribir por WhatsApp, el bot empiece el flujo desde cero.
  descartadoEn           DateTime?

  // Conversación
  mensajeCliente         String?     @db.Text
  respuestaBot           String?     @db.Text

  updatedAt              DateTime    @updatedAt

  historial        MensajeHistorial[]
  humanTakeover    HumanTakeover?
  ventas           Venta[]
  cotizaciones     Cotizacion[]
  // Restrict: el personaje del catálogo no se borra si tiene leads asociados
  personaje        PersonajeShow? @relation(fields: [personajeId], references: [id], onDelete: SetNull)

  @@index([pasoActual])
  @@index([ranking])
  @@index([updatedAt])
  @@index([tipoNegocio])
  @@map("leads_crm")
}

// ─── HISTORIAL DE MENSAJES ───────────────────────────────────────────────────
// Replica hoja HISTORIAL del Google Sheet

model MensajeHistorial {
  id          String   @id @default(cuid())
  leadId      String
  telefono    String
  hashMensaje String?  @unique     // evita duplicados
  rol         String               // "cliente" | "bot"
  mensaje     String   @db.Text
  pasoActual  String?
  timestamp   DateTime @default(now())

  lead LeadCRM @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([telefono])
  @@map("historial_mensajes")
}

// ─── HUMAN TAKEOVER ──────────────────────────────────────────────────────────
// Replica hoja HUMAN_TAKEOVER del Google Sheet

model HumanTakeover {
  id                   String   @id @default(cuid())
  leadId               String   @unique
  telefono             String   @unique
  agenteActivo         Boolean  @default(false)
  timestampUltimoAgente DateTime?
  updatedAt            DateTime @updatedAt

  lead LeadCRM @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("human_takeover")
}

// ─── OPT-OUT ─────────────────────────────────────────────────────────────────
// Replica hoja OPT_OUT del Google Sheet

model OptOut {
  id       String   @id @default(cuid())
  telefono String   @unique
  mensaje  String?  @db.Text
  fecha    DateTime @default(now())

  @@map("opt_out")
}

// ─── LOGÍSTICA PENDIENTE ─────────────────────────────────────────────────────
// Replica hoja LOGISTICA_PENDIENTE del Google Sheet

model LogisticaPendiente {
  id               String   @id @default(cuid())
  telefono         String
  nombreCliente    String?
  medida           String?
  marcaLlanta      String?
  cantidad         Int      @default(1)
  precioUnit       Decimal? @db.Decimal(10, 2)
  localOrigen      Json?
  localDestino     Json?
  tipoLogistica    String?  // "traslado" | "despacho_almacen"
  estado           String   @default("pendiente")
  observaciones    String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("logistica_pendiente")
}

// ─── COTIZACIONES ────────────────────────────────────────────────────────────

model Cotizacion {
  id              String           @id @default(cuid())
  numero          String           @unique
  tipoNegocio     TipoNegocio      @default(LLANTAS)
  leadId          String?
  usuarioId       String

  // Datos del cliente (snapshot del lead)
  telefonoCliente String?
  nombreCliente   String?
  dniCe           String?
  marcaAuto       String?
  modeloAuto      String?
  anioAuto        Int?

  // Producto cotizado (campos principales = primer ítem, por compatibilidad)
  medidaLlanta    String?
  marcaLlanta     String?
  modeloLlanta    String?
  cantidad        Int              @default(1)
  precioUnit      Decimal          @db.Decimal(10, 2) @default(0)
  descuento       Decimal?         @db.Decimal(10, 2)
  // Recargo que el vendedor decidió cobrarle al cliente (pago con tarjeta 4%
  // y/o traslado entre tiendas S/30) — solo la parte "asumida por el cliente".
  // El detalle de cuál se aplicó y quién la asumió queda en notas.
  cargoAdicional  Decimal?         @db.Decimal(10, 2)
  precioTotal     Decimal          @db.Decimal(10, 2) @default(0)
  // Ítems múltiples: [{ sku, medida, marca, modelo, cantidad, precioUnit }]
  items           Json?

  // Datos de la cita (snapshot del lead)
  fechaCita        String?
  fechaInstalacion DateTime?        // día de instalación elegido en el CRM
  horaInstalacion  String?          // hora de instalación
  localInstalacion Json?
  provinciaDestino String?
  caso             CasoFlujo?
  esTraslado       Boolean          @default(false)
  generarCita      Boolean          @default(false) // si el vendedor activó generar cita

  // Estado y notas
  estado          EstadoCotizacion @default(BORRADOR)
  motivoRechazo   String?          @db.Text // razón cuando estado = RECHAZADA
  notas           String?          @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // SetNull: si se borra el lead la cotizacion queda sin lead pero no se pierde
  lead    LeadCRM?   @relation(fields: [leadId],   references: [id], onDelete: SetNull)
  // Restrict: no borrar usuario con cotizaciones activas
  usuario Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  venta   Venta?

  @@index([estado])
  @@index([usuarioId])
  @@index([leadId])
  @@index([tipoNegocio])
  @@map("cotizaciones")
}

// ─── VENTAS ──────────────────────────────────────────────────────────────────
// Enriquecida con campos del Registro_Ventas sheet de n8n

model Venta {
  id               String        @id @default(cuid())
  numero           String        @unique
  tipoNegocio      TipoNegocio   @default(LLANTAS)
  leadId           String?                        // link al lead WhatsApp
  clienteId        String?                        // para ventas en tienda
  usuarioId        String

  // Datos cliente (redundante para ventas sin lead)
  telefonoCliente  String?
  nombreCliente    String?
  dniCe            String?
  tipoDoc          TipoDoc?
  marcaAuto        String?
  modeloAuto       String?
  anioAuto         Int?

  // Llanta
  medidaLlanta     String?
  marcaLlanta      String?
  modeloLlanta     String?
  cantidad         Int           @default(1)
  precioUnit       Decimal       @db.Decimal(10, 2) @default(0)
  precioTotal      Decimal       @db.Decimal(10, 2) @default(0)
  itemsLlanta      Json?         // múltiples llantas cotizadas: [{ sku, medida, marca, modelo, cantidad, precioUnit }]

  // Cotización origen
  cotizacionId     String?       @unique
  cotizacion       Cotizacion?   @relation(fields: [cotizacionId], references: [id])

  // Flujo n8n
  tipoVenta        String?       // "whatsapp" | "tienda" | "web"
  caso             CasoFlujo?
  esTraslado       Boolean       @default(false)
  localInstalacion Json?
  direccionLocal   String?
  provinciaDestino String?
  fechaCita        String?
  fechaInstalacion DateTime?
  horaInstalacion  String?
  calendarId       String?
  rankingLead      RankingLead?
  estadoLogistica  String?

  estado           EstadoVenta   @default(PENDIENTE)
  descuentoTipo    TipoDescuento?
  descuentoValor   Decimal?      @db.Decimal(10, 2)
  descuentoMotivo  String?

  createdAt        DateTime      @default(now())

  // SetNull: si se borra el lead, la venta queda sin lead pero no se pierde
  lead         LeadCRM?      @relation(fields: [leadId],    references: [id], onDelete: SetNull)
  // Restrict: no borrar usuario con ventas — desactivarlo en su lugar
  usuario      Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  items        ItemVenta[]
  comprobantes Comprobante[]

  @@index([estado])
  @@index([usuarioId])
  @@index([createdAt])
  @@index([leadId])
  @@index([tipoNegocio])
  @@map("ventas")
}

model ItemVenta {
  id         String  @id @default(cuid())
  ventaId    String
  productoId String
  sedeId     String
  cantidad   Int
  precioUnit Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [ventaId],    references: [id], onDelete: Cascade)
  // Restrict: no borrar producto/sede si hay ventas históricas que lo referencian
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  sede     Sede     @relation(fields: [sedeId],     references: [id], onDelete: Restrict)

  @@map("items_venta")
}

// ─── FACTURACIÓN SUNAT ───────────────────────────────────────────────────────

model Comprobante {
  id           String            @id @default(cuid())
  ventaId      String
  tipo         TipoComprobante
  serie        String
  correlativo  String
  estado       EstadoComprobante @default(PENDIENTE)
  xmlUrl       String?
  cdrUrl       String?
  hashCdr      String?
  fechaEmision DateTime          @default(now())
  createdAt    DateTime          @default(now())

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@map("comprobantes")
}

model ConfigSunat {
  id                 String       @id @default(cuid())
  rucEmpresa         String
  razonSocialEmpresa String
  certificadoPath    String?
  pse                PseProvider?
  pseApiKey          String?
  pseApiUrl          String?
  seriesBoleta       String       @default("B001")
  seriesFactura      String       @default("F001")
  activo             Boolean      @default(false)

  @@map("config_sunat")
}

// Config de APIs externas de búsqueda (DNI/RUC/CE, placa, IA). Fila única.
model ConfigApiBusqueda {
  id             String   @id @default(cuid())
  dniUrl         String?
  dniKey         String?
  rucUrl         String?
  rucKey         String?
  ceUrl          String?
  ceKey          String?
  factilizaUrl   String?
  factilizaToken String?
  groqKey        String?
  geminiKey      String?
  iaPrioridad    String   @default("groq")  // "groq" | "gemini" (cuál se intenta primero)
  groqActivo     Boolean  @default(true)
  geminiActivo   Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  @@map("config_api_busqueda")
}

// ─── ALERTAS ─────────────────────────────────────────────────────────────────

model AlertaStock {
  id             String   @id @default(cuid())
  productoId     String
  sedeId         String
  cantidadActual Int
  stockMinimo    Int
  resuelta       Boolean  @default(false)
  createdAt      DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sede     Sede     @relation(fields: [sedeId],     references: [id], onDelete: Cascade)

  @@index([resuelta])
  @@index([productoId])
  @@map("alertas_stock")
}

// ─── NEGOCIO "EL PATRÓN" (shows de personajes) ───────────────────────────────
// Catálogo administrado desde el CRM, vista "Detalles del Patrón"

model PersonajeShow {
  id          String        @id @default(cuid())
  nombre      TipoPersonaje @unique
  precioBase  Decimal       @default(150) @db.Decimal(10, 2)
  descripcion String?
  imagenUrl   String?
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  leads LeadCRM[]

  @@map("personajes_show")
}

model DistritoCobertura {
  id                   String   @id @default(cuid())
  distrito             String   @unique
  costoTransporteAprox Decimal? @db.Decimal(10, 2)
  activo               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("distritos_cobertura")
}

model AgregadoRegalo {
  id        String       @id @default(cuid())
  nombre    String
  tipo      TipoAgregado
  precio    Decimal      @db.Decimal(10, 2)
  activo    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("agregados_regalo")
}

// ─── WEBHOOK LOGS ─────────────────────────────────────────────────────────────

model WebhookLog {
  id        String        @id @default(cuid())
  origen    OrigenWebhook
  payload   Json?
  respuesta Json?
  estado    String?
  usuarioId String?
  createdAt DateTime      @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("webhook_logs")
}

// ─── COLA DE REINTENTOS WHATSAPP ─────────────────────────────────────────────

model ColaReintento {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  telefono      String
  mensajeBody   String   @db.Text
  intentos      Int      @default(0)
  status        String   @default("pendiente")
  errorDetalle  String?
  updatedAt     DateTime @updatedAt

  @@map("cola_reintentos")
}
